
# ============================================================
# Configuração do Pipeline 3D
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Nome do arquivo .laz dentro da pasta ./input/
INPUT_FILE=TeuARQUIVOLazAqui

# --- Instant Meshes ---
# Número alvo de vértices na retopologia
TARGET_VERTICES=80000

# --- PyMeshLab (Screened Poisson) ---
# Profundidade do Screened Poisson (8=rápido/simples, 10=padrão, 12=detalhado)
POISSON_DEPTH=10

# --- CloudCompare (SOR) ---
# Número de vizinhos para o filtro Statistical Outlier Removal
SOR_NEIGHBORS=20
# Multiplicador do desvio padrão (menor = mais agressivo)
SOR_STD=1.5

# --- CloudCompare (Spatial Subsampling) ---
# Distância mínima entre pontos em metros
SPATIAL_SUBSAMPLE=0.5
